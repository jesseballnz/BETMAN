# ──────────────────────────────────────────────────────────────────────────────
# BETMAN environment configuration
# Copy to .env and fill in the values for your deployment.
# ──────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string (required for DB features, optional for file-only mode)
# DATABASE_URL=postgresql://betman:betman@localhost:5432/betman
# BETMAN_DATABASE_URL=postgresql://betman:betman@localhost:5432/betman

# ── Server ───────────────────────────────────────────────────────────────────
# PORT=8080
# HOST=0.0.0.0

# ── Authentication ───────────────────────────────────────────────────────────
# BETMAN_USERNAME=betman
# BETMAN_PASSWORD=change-me-now
# BETMAN_SESSION_TTL_MS=43200000

# ── Poll Manager ─────────────────────────────────────────────────────────────
# Base racing-poll interval in seconds (default 60)
# POLL_SECONDS=60
# Meeting-profile refresh interval in minutes (default 30)
# PROFILE_REFRESH_MIN=30
# How often to persist poll-manager state in seconds (default 15)
# STATE_WRITE_INTERVAL=15

# ── AI / LLM ────────────────────────────────────────────────────────────────
# BETMAN_CHAT_PROVIDER=ollama
# BETMAN_CHAT_MODEL=llama3.1:8b
# BETMAN_OLLAMA_BASE_URL=http://localhost:11434
# OPENAI_API_KEY=
# BETMAN_OPENAI_API_KEY=

# ── Stripe payments ──────────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_LINK_SINGLE=
# STRIPE_LINK_SINGLE_DAY=
# STRIPE_LINK_COMMERCIAL=
# STRIPE_LINK_TESTER=

# ── Bookmaker automation ────────────────────────────────────────────────────
# TAB_USERNAME=
# TAB_PASSWORD=
# BETCHA_USERNAME=
# BETCHA_PASSWORD=
# AUTOBET_TAB_LIVE=false
# AUTOBET_BETCHA_LIVE=false

# ── Data history ─────────────────────────────────────────────────────────────
# BETMAN_RUNNER_HISTORY_DAYS=120
# BETMAN_RUNNER_SPELL_DAYS=60

# ── Sports polling (sporter) ────────────────────────────────────────────────
# SPORTER_POLL_INTERVAL_MS=60000
# SPORTER_TAB_URL=
# SPORTER_DRAFTKINGS_URL=
# SPORTER_FANDUEL_URL=

# ── Backups ──────────────────────────────────────────────────────────────────
# BACKUP_DIR=./backups
# BACKUP_KEEP_DAYS=7
# BETMAN_DB_NAME=betman
# BETMAN_DB_USER=betman
# BETMAN_DB_PASS=betman
